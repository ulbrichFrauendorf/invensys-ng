{
  "name": "integra-ng",
  "version": "21.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:with-mcp": "node tools/mcp/run-with-ui.mjs",
    "mcp": "node tools/mcp/integra-ng-mcp-server.mjs --http",
    "mcp:stdio": "node tools/mcp/integra-ng-mcp-server.mjs --stdio",
    "build": "ng build integra-ng && ng build ui-kit && npm run build:mcp-catalog",
    "build:mcp-catalog": "node tools/mcp/generate-catalog.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "primeicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.2.12",
    "@types/jasmine": "~5.1.0",
    "baseline-browser-mapping": "^2.9.6",
    "chart.js": "^4.5.1",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.0.0",
    "typescript": "^5.9.3"
  }
}
